@model List<RestauranteApp.Models.Producto>

@{
    ViewData["Title"] = "Administración de Productos";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h3 class="mb-0"><i class="bi bi-box-seam me-2"></i>Gestión de Productos</h3>
            <a asp-action="Crear" class="btn btn-success shadow-sm">
                <i class="bi bi-plus-circle"></i> Agregar Nuevo Producto
            </a>
        </div>
        
        <div class="card-body bg-light border-bottom py-2"> <div class="row g-2">
                <div class="col-md-7">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" id="buscarNombre" class="form-control" placeholder="Buscar por nombre...">
                    </div>
                </div>
                <div class="col-md-5">
                    <select id="buscarCategoria" class="form-select">
                        <option value="">Todas las Categorías</option>
                        <option value="Comidas">Comidas</option>
                        <option value="Bebidas">Bebidas</option>
                        <option value="Postres">Postres</option>
                        <option value="Cafetería">Cafetería</option>
                        <option value="Otros">Otros</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="tablaProductos">
                    <thead class="table-light text-center">
                        <tr>
                            <th style="width: 12%;">Imagen</th>
                            <th class="text-start" style="width: 38%;">Nombre del Producto</th>
                            <th style="width: 15%;">Categoría</th>
                            <th class="text-end" style="width: 15%; padding-right: 25px;">Precio</th>
                            <th style="width: 20%;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var catNombre = item.IdCategoria switch {
                                1 => "Comidas",
                                2 => "Bebidas",
                                3 => "Postres",
                                4 => "Cafetería",
                                _ => "Otros"
                            };

                            <tr class="producto-fila">
                                <td class="text-center py-1"> 
                                    <img src="@item.Imagen" alt="Prod" 
                                         style="width: 55px; height: 55px; object-fit: cover; border-radius: 10px; border: 1px solid #ddd;" 
                                         onerror="this.src='/imagenes/productos/default.png';"/>
                                </td>
                                <td class="text-start py-1">
                                    <span class="fw-bold text-dark nombre-prod">@item.Nombre</span>
                                </td>
                                <td class="text-center py-1">
                                    <span class="badge rounded-pill bg-info text-dark px-3 categoria-prod" style="font-size: 0.8rem;">
                                        @catNombre
                                    </span>
                                </td>
                                <td class="text-end fw-bold text-success py-1" style="padding-right: 25px;">
                                    $ @item.Precio.ToString("N2")
                                </td>
                                <td class="text-center py-1">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-action="Editar" asp-route-id="@item.IdProducto" 
                                           class="btn btn-warning btn-sm text-white px-2">
                                            <i class="bi bi-pencil-square"></i> Editar
                                        </a>
                                        <a asp-action="Eliminar" asp-route-id="@item.IdProducto" 
                                           class="btn btn-danger btn-sm px-2"
                                           onclick="return confirm('¿Está seguro de eliminar este producto?')">
                                            <i class="bi bi-trash"></i> Eliminar
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            function filtrarTabla() {
                var nombre = $("#buscarNombre").val().toLowerCase();
                var categoria = $("#buscarCategoria").val().toLowerCase();

                $("#tablaProductos tbody tr").each(function () {
                    var textoNombre = $(this).find(".nombre-prod").text().toLowerCase();
                    var textoCategoria = $(this).find(".categoria-prod").text().trim().toLowerCase();

                    var coincideNombre = textoNombre.indexOf(nombre) > -1;
                    var coincideCategoria = categoria === "" || textoCategoria === categoria;

                    if (coincideNombre && coincideCategoria) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            }

            $("#buscarNombre").on("keyup", filtrarTabla);
            $("#buscarCategoria").on("change", filtrarTabla);
        });
    </script>
}