@using RestauranteApp.Models
@model List<DetalleCajaViewModel>

@{
    Layout = null;
}

<div class="modal-header bg-dark text-white">
    <h5 class="modal-title">Ticket Mesa #@ViewBag.IdMesa</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    @if (ViewBag.MesaVacia == true)
    {
        <div class="alert alert-warning text-center my-3">
            <i class="bi bi-exclamation-triangle-fill" style="font-size: 2rem;"></i>
            <h4 class="mt-2">Mesa sin consumo</h4>
            <p>La comanda está abierta pero no se han cargado productos.</p>
        </div>
    }
    else
    {
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Cant</th>
                    <th>Producto</th>
                    <th class="text-end">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Cant</td>
                        <td>@item.Nombre</td>
                        <td class="text-end">$@item.Sub</td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="d-flex justify-content-between border-top pt-2">
            <h4>TOTAL:</h4>
            <h4 class="text-success fw-bold">$@ViewBag.Total.ToString("N2")</h4>
        </div>
    }
</div>

<div class="modal-footer flex-column">
    @if (ViewBag.MesaVacia != true)
    {
        <p class="text-muted small mb-2">Seleccione el método de pago:</p>
        <div class="d-flex gap-2 w-100 mb-2">
            <button type="button" class="btn btn-success flex-fill" onclick="procesarPago('EFECTIVO')">
                <i class="bi bi-cash"></i> EFECTIVO
            </button>
            <button type="button" class="btn btn-primary flex-fill" onclick="procesarPago('TRANSFERENCIA')">
                <i class="bi bi-bank"></i> TRANSF.
            </button>
            <button type="button" class="btn btn-info text-white flex-fill" onclick="procesarPago('TARJETA')">
                <i class="bi bi-credit-card"></i> TARJETA
            </button>
        </div>
        
        @* <button type="button" class="btn btn-outline-secondary w-100 btn-sm" onclick="window.ejecutarImpresion(@ViewBag.IdMesa)">
            <i class="bi bi-printer"></i> SOLO IMPRIMIR PRE-CUENTA
        </button> *@
    }
    else
    {
        <button type="button" class="btn btn-warning w-100" onclick="procesarPago('VACIA')">
            <i class="bi bi-door-open"></i> CERRAR Y LIBERAR MESA VACÍA
        </button>
    }
</div>

<script>
    window.ejecutarImpresion = function(idMesa) {
        var url = '@Url.Action("ImprimirTicket", "Ventas")' + '?idMesa=' + idMesa;
        var win = window.open(url, '_blank');
        if (win) win.focus();
    };

  window.procesarPago = function(metodo) {
    const idC = @ViewBag.IdComanda;
    const idM = @ViewBag.IdMesa;

    if (confirm("¿Confirmar cobro en " + metodo + " y liberar mesa?")) {
        $(".btn").prop("disabled", true);

        $.post('@Url.Action("CerrarMesa", "Ventas")', { 
            idComanda: idC, 
            idMesa: idM, 
            metodoPago: metodo 
        }, function(res) {
            if (res.success) {
                if (metodo !== 'VACIA') {
                    if (confirm("¡Venta registrada! ¿Desea imprimir el ticket?")) {
                        // REDIRECCIÓN DIRECTA (No falla nunca)
                        window.location.href = '@Url.Action("ImprimirTicket", "Ventas")' + '?idMesa=' + idM;
                    } else {
                        window.location.reload();
                    }
                } else {
                    window.location.reload();
                }
            } else {
                alert("Error: " + res.message);
                $(".btn").prop("disabled", false);
            }
        });
    }
};
</script>